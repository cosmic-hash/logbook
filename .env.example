# Supabase (recommended — instant, no KV approval wait)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# EdgeOne AI (optional — local parser works without it)
MAKERS_MODELS_KEY=

# Gmail integration (optional — see docs/gmail-integration.md)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8088/api/gmail/callback

# MCP server (optional — which account to manage via MCP tools)
LOGBOOK_EMAIL=
